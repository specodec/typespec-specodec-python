{
  "name": "@specodec/typespec-specodec-python",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/src/index.js",
  "typespec": {
    "emitter": true,
    "options": {
      "@specodec/typespec-specodec-python": {
        "type": "object",
        "properties": { "emitter-output-dir": { "type": "string" } },
