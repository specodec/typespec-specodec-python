      }
    }
  },
  "scripts": { "build": "tsc", "prepare": "npm run build" },
  "devDependencies": {
    "@typespec/compiler": "1.11.0",
    "@typespec/http": "1.11.0",
    "typescript": "^5.8.0"
  }
